# ── Node.js API Gateway ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# MongoDB – use Atlas URI in production
MONGODB_URI=mongodb://localhost:27017/bodyfitai

# Comma-separated list of allowed browser origins (CORS whitelist)
# Development:
ALLOWED_ORIGINS=http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://your-app.com,https://www.your-app.com

# ── Python Microservice (private — Node.js only, never the browser) ──────────
# The Python FastAPI backend runs as a private microservice.
# Only Node.js calls this URL; the browser never talks to it directly.
PYTHON_SERVICE_URL=http://localhost:8000

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=change_me_to_a_random_secret